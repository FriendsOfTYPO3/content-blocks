                      ]
                    },
                    "fieldControl": {
                      "type": "object"
                    },
                    "fieldInformation": {
                      "type": "object"
                    },
                    "fieldWizard": {
                      "type": "object",
                      "properties": {
                        "defaultLanguageDifferences": {
                          "type": "object"
                        },
                        "localizationStateSelector": {
                          "type": "object"
                        },
                        "otherLanguageContent": {
                          "type": "object"
                        }
                      }
                    },
                    "mode": {
