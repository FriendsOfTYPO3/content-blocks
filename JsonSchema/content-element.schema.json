                      "default": 30
                    },
                    "valuePicker": {
                      "$ref": "#/allOf/1/properties/fields/items/allOf/0/then/properties/valuePicker"
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "type": {
                      "const": "Color"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                "then": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "identifier": {},
                    "label": {},
                    "description": {},
                    "useExistingField": {},
                    "prefixField": {},
                    "prefixType": {},
                    "displayCond": {},
                    "onChange": {},
