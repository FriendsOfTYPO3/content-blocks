{
	"$schema": "http://json-schema.org/draft-07/schema",
	"$id": "http://typo3.org/content-element.json",
	"title": "Content Element",
	"description": "TYPO3 CMS Content Blocks Content Element",
	"additionalProperties": false,
	"properties": {
		"description": {},
		"group": {},
		"typeName": {},
		"saveAndClose": {},
		"name": {},
		"title": {},
		"prefixFields": {},
		"prefixType": {},
		"vendorPrefix": {},
		"priority": {},
		"basics": {},
		"fields": {},
		"table": {},
		"typeField": {},
		"labelField": {},
		"fallbackLabelFields": {}
	},
	"allOf": [
		{
			"type": "object",
			"properties": {
				"table": {
					"type": "string",
					"const": "tt_content"
				},
				"typeField": {
					"type": "string",
					"const": "CType"
				},
				"description": {
					"description": "The description of the Content Block",
					"type": "string"
				},
				"group": {
					"description": "Group name the Content Block should be displayed in",
					"anyOf": [
						{
							"type": "string"
						},
						{
							"type": "string",
							"enum": ["default", "lists", "menu", "forms", "special", "plugins"]
						}
					],
					"default": "default"
				},
				"typeName": {
					"description": "Unqique type identifier for this Content Block",
					"type": "string",
					"examples": ["my_accordion"]
				},
				"saveAndClose": {
					"description": "New Content Elements will skip the edit view.",
					"type": "boolean",
					"default": false
				},
				"labelField": {
					"description": "Defines which field should be used as the title of the record.",
					"oneOf": [
						{
							"type": "string"
						},
						{
							"type": "array",
							"items": {
								"type": "string"
							}
						}
					]
				},
				"fallbackLabelFields": {
					"description": "Defines which fields should be used as fallback, if labelField is not filled.",
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			}
		},
		{
			"$ref": "content-type.json"
		}
	]
}
