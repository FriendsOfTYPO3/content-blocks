								"type": {
									"const": "Password"
								}
							},
							"required": ["type"]
						},
						"then": {
							"$ref": "password.json"
						}
					},
					{
						"if": {
							"properties": {
								"type": {
									"const": "Relation"
								}
							},
							"required": ["type"]
						},
						"then": {
							"$ref": "relation.json"
						}
					},
					{
						"if": {
							"properties": {
								"type": {
									"const": "Slug"
								}
