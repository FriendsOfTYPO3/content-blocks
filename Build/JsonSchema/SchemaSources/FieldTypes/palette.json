							"required": ["type"]
						},
						"then": {
							"$ref": "checkbox.json"
						}
					},
					{
						"if": {
							"properties": {
								"type": {
									"const": "Category"
								}
							},
							"required": ["type"]
						},
						"then": {
							"$ref": "category.json"
						}
					},
					{
						"if": {
							"properties": {
								"type": {
